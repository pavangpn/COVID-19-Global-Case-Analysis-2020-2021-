   "source": [
    "Task 10: Top 5 Countries by COVID‑19 Death Rate (2020)  "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d7124146-141c-4fef-9a1d-6198ec1cf3ae",
   "metadata": {},
   "source": [
    "This task calculates the death rate (deaths/confirmed cases) for each country in 2020 and highlights the five countries with the highest values."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 269,
   "id": "9e597375-88c4-4a2c-8b11-0da041b4a989",
   "metadata": {},
   "outputs": [],
   "source": [
    "deaths=df_d[[\"Country/Region\",\"12/31/2020\"]]\n",
    "confirmed=df_c[[\"Country/Region\",\"12/31/2020\"]]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 271,
   "id": "53b1d917-7fab-4ae4-8982-1e537f0884be",
   "metadata": {},
   "outputs": [],
   "source": [
    "confirmed=confirmed.rename(columns={\"Country/Region\":\"Country\",\"12/31/2020\":\"confirmed_cases\"})\n",
    "deaths=deaths.rename(columns={\"Country/Region\":\"Country\",\"12/31/2020\":\"deaths\"})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 283,
   "id": "01b9766c-8091-44cb-b789-fe4c190fe8f2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# merging the resultant datasets using pd.merge() \n",
    "combined=pd.merge(confirmed,deaths,on=\"Country\")"
   ]
  },
