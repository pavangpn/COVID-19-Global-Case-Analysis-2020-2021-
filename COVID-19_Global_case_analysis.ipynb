   "outputs": [],
   "source": [
    "# In the raw datasets of covid19 confirmed cases(df_c) and recoveries (df_r),the dates are inconsistent,\n",
    "# to make the date values consistent and clean,defined a function date_clean().\n",
    "# We use this function to turn the dates in to one single format.\n",
    "\n",
    "from datetime import datetime\n",
    "\n",
    "def date_clean(x):\n",
    "    if '-' in x:\n",
    "        if '.' not in x:\n",
    "            if int(x.split(\"-\")[0])==1:\n",
    "                x=x+\"-2021\"\n",
    "            else:    \n",
    "                x=x+\"-2020\"\n",
    "            date_fmt=datetime.strptime(x,\"%d-%b-%Y\")\n",
    "            d=date_fmt.strftime(\"%d/%m/%Y\")\n",
    "            return d\n",
    "        else:\n",
    "            a=x.split(\".\")[0]\n",
    "            x=a+\"-2021\"\n",
    "            date_fmt=datetime.strptime(x,\"%d-%b-%Y\")\n",
    "            d=date_fmt.strftime(\"%d/%m/%Y\")\n",
    "            return d\n",
    "    else:\n",
    "        return x"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 115,
   "id": "8eaf79ea-020d-457b-b7c9-517b52565e9d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# defining a function to make the dates in the COVID-19 deaths dataset consistent and understandable.\n",
    "\n",
    "def fixdate(x):\n",
    "    if \".\" in x:\n",
    "        a=x.split(\".\")\n",
    "        x=a[0]\n",
    "        \n",
    "    parts=x.split(\"/\")\n",
    "    d,m,y=int(parts[0]),int(parts[1]),int(parts[2])\n",
    "    if m>12:\n",
    "        d,m=m,d\n",
    "    return f\"{d}/{m}/{y}\""
   ]
  },
