   "cell_type": "code",
   "execution_count": 285,
   "id": "263bfc65-c334-4ee6-ace2-89693fe3b5a2",
   "metadata": {},
   "outputs": [],
   "source": [
    "combined1=combined.groupby(\"Country\").sum().reset_index()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 288,
   "id": "074a031e-6ef6-4d2c-8a45-7f646b875eb6",
   "metadata": {},
   "outputs": [],
   "source": [
    "combined1[\"death_rate\"]=combined1[\"deaths\"]*100/combined1[\"confirmed_cases\"]"
   ]
  },
